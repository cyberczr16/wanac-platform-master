# WANAC API (main backend). Used by services (sessions, fireteams, etc.). Set to your backend URL (e.g. https://api.wanac.org).
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_URL=

# OpenAI (transcription, summaries, chat) – optional if using Hugging Face
NEXT_PUBLIC_OPENAI_API_KEY=sk-proj-your-key
OPENAI_API_KEY=sk-proj-your-key
NEXT_PUBLIC_OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_URL=https://api.openai.com/v1

# Hugging Face (recording transcription + summaries – free tier)
# Get token at https://huggingface.co/settings/tokens (Read)
NEXT_PUBLIC_HUGGINGFACE_API_KEY=
# HUGGINGFACE_API_KEY=

# LiveKit (video meetings)
# Public URL of your LiveKit server (e.g. wss://your-livekit-host)
NEXT_PUBLIC_LIVEKIT_URL=
# Server-side API key/secret used ONLY to sign access tokens (never expose secret to browser)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Google OAuth (authentication & calendar)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=
# Optional: custom AI service (ai.service.ts)
# NEXT_PUBLIC_AI_API_URL=
# NEXT_PUBLIC_AI_API_KEY=
