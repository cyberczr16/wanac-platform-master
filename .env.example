# WANAC API (main backend). Used by services (sessions, fireteams, etc.). Set to your backend URL (e.g. https://api.wanac.org).
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_URL=

# Groq (Fireteam: transcription, evaluation, summaries, /api/chat) — https://console.groq.com
# Server-side only; never use NEXT_PUBLIC_ for the API key.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Optional: GROQ_MODEL_EVALUATION, GROQ_MODEL_SUMMARY, GROQ_MODEL_CHAT (see src/app/api/groq/*)

# LiveKit (video meetings)
# Public URL of your LiveKit server (e.g. wss://your-livekit-host)
NEXT_PUBLIC_LIVEKIT_URL=
# Server-side API key/secret used ONLY to sign access tokens (never expose secret to browser)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Google OAuth (authentication & calendar)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=
# Optional: custom AI service (ai.service.ts)
# NEXT_PUBLIC_AI_API_URL=
# NEXT_PUBLIC_AI_API_KEY=
