APP_NAME="Fireteam API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database (PostgreSQL — fireteam schema) ──────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fireteam
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_SCHEMA=fireteam

# ── Queue (use 'database' to start, switch to 'redis' in production) ──
QUEUE_CONNECTION=database

# ── Groq AI (free tier — get key at console.groq.com) ───
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Model selection (current active models as of April 2026)
GROQ_MODEL_EVALUATION=llama-3.3-70b-versatile
GROQ_MODEL_SUMMARY=llama-3.1-8b-instant
GROQ_MODEL_WHISPER=whisper-large-v3

# Audio chunk settings
AUDIO_CHUNK_SECONDS=30
AUDIO_MAX_MB=25

# ── CORS — allow Next.js frontend to call this API ───────
FRONTEND_URL=http://localhost:3000

# ── Sanctum (API auth) ───────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000
